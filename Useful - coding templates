--Glowing popup generator!--<

//Creates a glowing popup of whatever text you plug in!
//Usage: coolPopup(text, color, total popup time in milliseconds)
//Example: coolPopup("+" + args[1] + " coins!" , "gold" , 3000)
//Example 2: coolPopup("Hello world!" , "#23e84e" , 1500)
//Code:

function coolPopup(text,colour,time){
  //safety margins
  const marginX = 150;
  const marginY = 80;
  let left = marginX + Math.random() * (window.innerWidth - marginX * 2);
  let top = marginY + Math.random() * (window.innerHeight - marginY * 2);
  
  //Create element
  let popup = $("<div class='fancypopup'>" + text + "</div>");
  
  //Style
  popup.css({
    position: "fixed",
    left: left + "px",
    top: top + "px",
    color: colour,
    fontWeight: "bold",
    fontSize: "20px",
    pointerEvents: "none",
    textShadow: "0 0 6px " + colour + ", 0 0 10px " + colour,
    transform: "scale(1)",
    opacity: 1,
    zIndex: 9999,
    background: "rgba(0, 0, 0, 0.3)",
    padding: "3px 4px",
    borderRadius: "1px",
  });
  
  //Add to page
  $("body").append(popup);
  
  //Random drift
  let driftX = (Math.random() - 0.5) * 60;
  let driftY = -40 - Math.random() * 40;
  
  //Animate float + fade
  popup.animate(
    {
      top: "+=" + driftY,
      left: "+=" + driftX,
      opacity: 0
    },
    {
      duration: time,
      step: function(now, fx) {
        if (fx.prop === "opacity") {
          let scale = 0.6 + now * 0.4;
          popup.css("transform", "scale(" + scale + ")");
        }
      },
      complete: function() {
        popup.remove();
      }
    }
  )
}

--Convert percentage to bar--<
//Converts a number you plug in to a very cool looking progress bar!
//Usage: makeBar(percentage)
//Example: makeBar(78) //Output: [████████████████----] 78%
//Example 2: makeBar(gwc.userdata.rankprogress.percentage) //Output: [████----------------] 20%
//I used this in a custom status tracker thing, it can be very cool:
//>---Exellinor---<
//Level: heroine
//Progress to titan: [████----------------] 20%
//Code:
  function makeBar(percent, length = 20) {
    percent = Math.max(0, Math.min(100, percent)); // clamp
    
    let filled = Math.round((percent / 100) * length);
    let empty = length - filled;
  
    let bar = "█".repeat(filled) + "-".repeat(empty);
  
    return `[${bar}] ${percent}%`;
  }

--Convert percentage to bar(html version)--<
//Same as previous one, but colored for html!
//Code:
  function makeCoolBar(percent, length = 20) {
    percent = Math.max(0, Math.min(100, percent));
    
    let filled = Math.round((percent / 100) * length);
    let empty = length - filled;
  
    let bar = "";
  
    for (let i = 0; i < filled; i++) {
      bar += `<span style="color:#22c55e;">█</span>`; // green
    }
    for (let i = 0; i < empty; i++) {
      bar += `<span style="color:#374151;">-</span>`; // gray
    }
  
    return `[${bar}] ${percent}%`;
  }

--Convert text to number--<

//Converts text such as thirty one or nine into digits, 31 or 9
//Usage: textToNumber(text);
//Example: textToNumber("ten") //output: "10"
//Usage example: convert numbers of coins looted for easier parsing(check out my Fun - Coin looting tracker)

//Code:

  function textToNumber(text) {
    text = text.toLowerCase().trim();
    if (text === "a" || text === "the") return 1;
  
    const ones = {
      zero:0, one:1, two:2, three:3, four:4,
      five:5, six:6, seven:7, eight:8, nine:9,
      ten:10, eleven:11, twelve:12, thirteen:13,
      fourteen:14, fifteen:15, sixteen:16,
      seventeen:17, eighteen:18, nineteen:19
    };
  
    const tens = {
      twenty:20, thirty:30, forty:40,
      fifty:50, sixty:60, seventy:70,
      eighty:80, ninety:90
    };
  
    let total = 0;
    let words = text.split(/\s+/);
    for (let w of words) {
      if (ones[w] !== undefined) total += ones[w];
      else if (tens[w] !== undefined) total += tens[w];
    }
    return total;
  }
