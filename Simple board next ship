Contains: 1 alias and 1 trigger

Description: An alias which, when used, boards the next ship automatically

IMPORTANT: Before using, change the alias's "purse" to whatever money container you use

Usage: boardnext

-----------------------------------------------------------------
Alias: boardnext

Execute the following Javascript:

//Change this to your money container
gwc.userdata.wallet = "purse"
//Change this if the name of your trigger is something different
var btrigger = "board ship auto"

if (gwc.userdata.boardingnext === "false"){
gwc.trigger.enable(btrigger);
gwc.output.append("Boarding next ship!","#15a395");
gwc.userdata.boardingnext = "true"
}

else if(gwc.userdata.boardingnext === "true"){
gwc.trigger.disable(btrigger);
gwc.output.append("Ship boarding cancelled","#15a395");
gwc.userdata.boardingnext = "false"
}

else if (!gwc.userdata.boardingnext){
 gwc.userdata.boardingnext = "true";
 gwc.trigger.enable(btrigger);
 gwc.output.append("Boarding next ship!","#15a395");
}

-----------------------------------------------------------------

Trigger: board ship auto

Type: Regexp

Pattern: Welcome to Genesis ShipLines|Last Call from Genesis ShipLines|All aboard|is thrown onto the

Execute the following Javascript: 

var wallet = gwc.userdata.wallet

gwc.connection.send("open " + wallet);
gwc.connection.send("get coins from " + wallet);
gwc.connection.send("buy tickets for team");
gwc.connection.send("put coins in " + wallet);
gwc.connection.send("board ship");
gwc.output.append("Ship boarded!","#15a395");
gwc.trigger.disable('board ship auto');
gwc.userdata.boardingnext = "false";
/*jshint ignore:start*/
await wait("1.5");
gwc.connection.send("close " + wallet);
