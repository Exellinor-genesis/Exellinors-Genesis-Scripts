function cout (text1 , color1 = "", text2="", color2=""){
  
gwc.output.append(text1 + text2, color1);
  
  if(color2 && text2){
  gwc.output.replace(text2 , color(text2, color2));
  }

}

// Easy coloring
  function color(text, color) { 
  return `<span style="color:${color};">${text}</span>` ; 
}

// Chop decimals
function toWhole(num) {
  return Math.trunc(num);
}

// Make bar 
  function makeBar(percent, length = 20) {
    percent = Math.max(0, Math.min(100, percent)); // clamp
    
    let filled = Math.round((percent / 100) * length);
    let empty = length - filled;
  
    let bar = "█".repeat(filled) + "-".repeat(empty);
  
    return `[${bar}] ${percent}%`;
  }

// Separator
function sep(color = c.sep[1]) {
    let sepp = `<span style="
      display:block;
      font-size:10px;
      line-height:8px;
      color:${color};
      letter-spacing:0px;
    ">     ─────────────────────────────────────────────────</span>`;
    gwc.output.append("SEPARATOR");gwc.output.replace("SEPARATOR",sepp)
  }

// Add commas to numbers
 function fn(num) {
 if (num == null) return "0";
 return Number(num).toLocaleString();
 }

// Easier args
function a(index, word) {
  return args[index] === word;
}

// SAVE BACKUP 
function backupTrax() {
  let trax = gwc.userdata.trax;
  if (!trax){
    out("No trax userdata to back up!")
  }
else if(trax){
 localStorage.setItem("traxBackup", JSON.stringify(trax));
 
  let saved = localStorage.getItem("traxBackup")
  let parsed = JSON.parse(saved);

      if (parsed && parsed.killz && parsed.coinloot) {
      out("Data successfully backed up!");
    }
}
}

// LOAD BACKUP
function loadTrax() {
  let saved = localStorage.getItem("traxBackup");
  if (!saved){
   out("No browser storage detected!") 
  }
  
else if(saved){
    let parsed = JSON.parse(saved);

      if (parsed && parsed.killz && parsed.coinloot) {
      gwc.userdata.trax = parsed;
      out("Data restored from backup!");
    }
}
}

