Alias: picmaps

Execute Javascript:
//stuff to mess with
var triggername = "Picture maps"
var textcolor = "#5f90de"

//nerd stuff
function out(text, color) {
      gwc.output.append(text, color || textcolor)
  }
var picmapstatus = gwc.userdata.picmapstatus
if(!picmapstatus){picmapstatus="off"}

//turn on
if (args[1] == "on"){
out("Picture maps turned on!")
out("Walk a room to activate it")
picmapstatus = "on"
gwc.trigger.enable(triggername)
}

//turn off
if (args[1] == "off"){
out("Picture maps turned off!")
picmapstatus = "off"
gwc.trigger.disable(triggername)
//close window
var win = document.getElementById("gwcMapWindow");
if (win) win.remove();
}

//usage
else if(!args["*"]){
  out("Usage: picmaps on | off");
  out("Picture maps are currently " + picmapstatus)
}

