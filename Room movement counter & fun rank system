//nerdstuff
let stored = JSON.parse(localStorage.getItem("walkData"))
if (!stored) return

function todayStamp() {
    const d = new Date()
    return d.toISOString().split("T")[0]
}

// Dailyflip
if (stored.daily.date !== todayStamp()) {

    stored.daily = {
        date: todayStamp(),
        count: 0
    }
}

// Count movement
stored.lifetime++
stored.daily.count++

if (stored.daily.count > stored.records.mostInDay) {
    stored.records.mostInDay = stored.daily.count
    stored.records.mostInDayDate = stored.daily.date
}

localStorage.setItem("walkData", JSON.stringify(stored))
